{:id          :isaac.cli.greeter
 :version     "0.1.0"
 :factory     isaac.module.protocol/module
 :description "A sample module that contributes a CLI subcommand"

 ;; Contributes to isaac.core's :isaac/cli berth.
 ;; The berth's per-entry factory (isaac.cli.registry/register-cli-command!)
 ;; resolves :run-fn and installs each entry as a CLI command.
 :isaac/cli   {:greet {:desc        "Print a greeting"
                       :usage       "greet"
                       :run-fn      isaac.cli.greeter/run-fn
                       :subcommands isaac.cli.greeter/subcommands}}}
