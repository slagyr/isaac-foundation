{:id          :marigold.cli.greeter
 :version     "0.1.0"
 :factory     isaac.module.protocol/module
 :description "Marigold fixture: sample module that contributes a CLI subcommand"

 ;; Contributes to isaac.foundation's :isaac/cli berth.
 ;; The berth's per-entry factory (isaac.cli.registry/register-cli-command!)
 ;; resolves :run-fn and installs each entry as a CLI command.
 :isaac/cli   {:greet {:usage     "greet"
                       :summary   "Print a greeting"
                       :namespace marigold.cli.greeter}}}