{:id        :isaac.foundation
 :version   "0.1.15"
 :factory   isaac.foundation.module/create-module

 :berths    {:isaac/cli           {:description "CLI commands installed into the top-level isaac command registry."
                                   :schema      {:type       :map
                                                 :key-spec   {:type :keyword}
                                                 :value-spec {:type    :map
                                                              :factory isaac.cli.registry/register-cli-command!
                                                              :schema  {:usage     {:type        :string
                                                                                    :validations [:present?]
                                                                                    :description "Usage line for isaac help (e.g. \"config <subcommand> [options]\"). Command name comes from the map key."}
                                                                        :summary   {:type        :string
                                                                                    :validations [:present?]
                                                                                    :description "One-line description shown in command listings and the help header."}
                                                                        :namespace {:type        :symbol
                                                                                    :validations [:present?]
                                                                                    :description "Namespace symbol that implements isaac.cli.api multimethods (run required; option-spec, subcommands, help optional)."}}}}}
             :isaac.config/schema {:description "Top-level config schema fragments contributed by modules."
                                   :schema      {:type       :map
                                                 :key-spec   {:type :keyword}
                                                 :value-spec {:type   :map
                                                              :schema {:schema             {:type        :map
                                                                                            :validations [:present?]
                                                                                            :description "Apron schema spec for this config table (types, validations, :dynamic-schema)."}
                                                                       :entity-dir         {:type        :string
                                                                                            :description "Config subdirectory for per-id entity files (e.g. \"crew\" → config/crew/*.edn)."}
                                                                       :frontmatter?       {:type        :boolean
                                                                                            :description "When true, entity-dir also accepts <id>.md with YAML frontmatter."}
                                                                       :merge-root-entity? {:type        :boolean
                                                                                            :description "Merge top-level isaac.edn entries for this key with entity files; error if same id appears in both."}
                                                                       :companion          {:type        :map
                                                                                            :description "Sidecar text for one entity field (inline value or companion file)."
                                                                                            :schema      {:field {:type        :keyword
                                                                                                                  :description "Entity key filled from file if omitted inline (:soul, :prompt, :template)."}
                                                                                                          :mode  {:type        :keyword
                                                                                                                  :description "exclusive | required | optional — see loader companion resolution."}}}}}}}
             :isaac.config/check  {:description "Post-load config validation checks contributed by modules."
                                   :schema      {:type       :map
                                                 :key-spec   {:type :keyword}
                                                 :value-spec {:type   :map
                                                              :schema {:fn {:type        :symbol
                                                                            :validations [:present?]
                                                                            :description "Symbol resolving to (fn [ctx] {:errors [] :warnings []})."}}}}}}

 :isaac.config/schema
 {:tz
  {:schema
   {:type        :string
    :description "IANA timezone name for this Isaac install; cron and other schedulers default here when no per-trigger zone is set."}}

  :prefer-entity-files
  {:schema
   {:type        :boolean
    :description "When true, config set writes/updates per-entity files (config/<dir>/<id>.edn) instead of inlining into isaac.edn."}}

  :logging
  {:schema
   {:type   :map
    :schema {:output    {:type        :keyword
                         :description "Log destination: :file (default), :stderr, :stdout, or :none. Server :file uses logs/server.log; CLI :file uses logs/cli.log."
                         :validations [[:maybe? [:one-of :file :stderr :stdout :none]]]}
             :max-bytes {:type        :int
                         :description "Rotate the server log when it exceeds this many bytes (default 100MB)."}
             :max-days  {:type        :int
                         :description "Drop rotated server logs older than this many days (default 30)."}}}}}

 :isaac/cli {:init   {:usage     "init"
                      :summary   "Scaffold a default Isaac config"
                      :namespace isaac.cli.registry}
             :logs   {:usage     "logs [options]"
                      :summary   "Print Isaac logs in readable colorized format"
                      :namespace isaac.logs.cli}
             :config  {:usage     "config <subcommand> [options]"
                       :summary   "Inspect and validate Isaac configuration"
                       :namespace isaac.config.cli.command}
             :modules {:usage     "modules <subcommand> [options]"
                       :summary   "Inspect and manage configured extension modules"
                       :namespace isaac.modules.cli}}}
